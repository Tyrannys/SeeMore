[add-section]
before=world-settings
key=underground
comment=# Additional view distance restriction applied underground.

[add-field]
key=underground.enabled
value=false
comment=# Whether underground view distance capping is enabled.

[add-field]
key=underground.underground-y
value=0.0
comment=# Apply the underground cap when a player goes below this Y level.

[add-field]
key=underground.surface-y
value=20.0
comment=# Remove the underground cap when a player goes above this Y level.

[add-field]
key=underground.maximum-view-distance
value=6
comment=# The maximum view distance allowed while underground.
